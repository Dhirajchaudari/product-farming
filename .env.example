NODE_ENV=development
HOST=0.0.0.0
PORT=8000

# Full URL (encode special chars in password, e.g. @ → %40)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/product_farming

# Or build from parts (useful in Docker / CI secrets)
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=product_farming

REDIS_URL=redis://localhost:6379

# Base64-encoded PEM key bodies (not file paths)
PUBLIC_KEY=
PRIVATE_KEY=

SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_BASE_URL=http://localhost:3000
SET_PASSWORD_PATH=/auth/set-password

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

DEFAULT_HR_EMAIL=hr@orbitalops.net
SEED_HR_PASSWORD=PayrollPilot@123
