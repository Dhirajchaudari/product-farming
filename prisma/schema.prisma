generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id             String   @id @default(uuid())
  fullName       String
  email          String   @unique
  employeeCode   String   @unique
  jobTitle       String
  department     String
  country        String
  salary         Decimal  @db.Decimal(12, 2)
  currency       String   @db.VarChar(3)
  dateOfJoining  DateTime
  employmentType String   @default("full_time")
  status         String   @default("active")
  managerName    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([country])
  @@index([country, jobTitle])
  @@index([department, country])
}

model AuthUser {
  id              String   @id @default(uuid())
  email           String   @unique
  role            String
  passwordHash    String?
  isEmailVerified Boolean  @default(false)
  firstLogin      Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  otps            EmailOtp[]
}

model EmailOtp {
  id         String   @id @default(uuid())
  email      String
  code       String
  role       String
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  user       AuthUser? @relation(fields: [email], references: [email])

  @@index([email, purpose])
  @@index([expiresAt])
}
